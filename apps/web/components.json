{
	"$schema": "https://ui.shadcn.com/schema.json",
	"style": "new-york",
	"rsc": true,
	"tsx": true,
	"tailwind": {
		"config": "",
		"css": "src/app/globals.css",
		"baseColor": "neutral",
		"cssVariables": true,
		"prefix": ""
	},
	"iconLibrary": "lucide",
	"aliases": {
		"components": "@/components",
		"utils": "@/lib/utils",
		"ui": "@/components/ui",
		"lib": "@/lib",
		"hooks": "@/hooks"
	},
	"registries": {
		"@intentui": "https://intentui.com/r/{name}",
		"@kibo-ui": "https://www.kibo-ui.com/r/{name}.json",
		"@reui": "https://reui.io/r/{name}.json",
		"@wigggle-ui": "https://wigggle-ui.vercel.app/r/{name}.json",
		"@react-bits": "https://reactbits.dev/r/{name}.json",
		"@reactbits-starter": {
			"url": "https://pro.reactbits.dev/api/r/starter/{name}.json",
			"headers": {
				"Authorization": "Bearer ${REACTBITS_LICENSE_KEY}"
			}
		},
		"@reactbits-pro": {
			"url": "https://pro.reactbits.dev/api/r/pro/{name}.json",
			"headers": {
				"Authorization": "Bearer ${REACTBITS_LICENSE_KEY}"
			}
		}
	}
}
