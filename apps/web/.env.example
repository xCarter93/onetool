# ---------------------------------------------------------------------------
# Client portal session JWT (PORTAL-03, PORTAL-05)
# ---------------------------------------------------------------------------
# Generate the keypair locally with:
#   pnpm tsx scripts/generate-portal-jwt-keys.ts
# The script prints all three lines below — copy them into apps/web/.env.local.
# DO NOT commit the private key. The JWKS (public) is safe to publish via
# /.well-known/portal-jwks.json. PORTAL_JWT_ISSUER must equal the public origin
# that serves the portal (it becomes the JWT `iss` claim).
PORTAL_JWT_PRIVATE_KEY=
PORTAL_JWT_JWKS=
PORTAL_JWT_ISSUER=https://app.onetool.biz
